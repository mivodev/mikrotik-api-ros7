{
    "name": "mivodev/mikrotik-api-ros7",
    "description": "Complete, universal PHP client for Mikrotik RouterOS v7 REST API. Framework-agnostic, zero-dependency.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/mivodev/mikrotik-api-ros7",
    "support": {
        "issues": "https://github.com/mivodev/mikrotik-api-ros7/issues",
        "source": "https://github.com/mivodev/mikrotik-api-ros7"
    },
    "keywords": [
        "mikrotik",
        "routeros",
        "api",
        "ros7",
        "rest",
        "curl",
        "hotspot",
        "pppoe",
        "radius",
        "isp"
    ],
    "authors": [
        {
            "name": "Mivo Enterprise",
            "email": "mivo@dev.dyzulk.com",
            "homepage": "https://github.com/mivodev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "autoload": {
        "psr-4": {
            "Mivo\\MikrotikRos7\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
